{
  "config": {
    "default_name": "主路由",
    "step": {
      "user": {
        "title": "连接到 iKuai 路由器",
        "description": "请输入 iKuai OpenAPI 地址和个人 API 令牌（Token）。必须使用 **HTTPS** 。\n 允许用户为每个 iKuai 连接设置一个自定义名称， \n 方便区分不同路由器的连接（如：主路由、二楼路由）。 \n 注：仅支持 **ikuai 4.0.221** 及以上版本。",
        "data": {
          "name": "连接名称 (如：主路由)",
          "host": "主机地址 (例如 https://10.10.10.1)",
          "token": "个人 API 令牌 (Token)"
        }
      },
      "reconfigure": {
        "title": "重新配置 iKuai 连接",
        "description": "更新当前集成的连接地址或令牌信息。",
        "data": {
          "host": "主机地址",
          "token": "个人 API 令牌 (Token)"
        }
      }
    },
    "error": {
      "cannot_connect": "无法连接到 iKuai，请检查地址、令牌以及是否开启了 HTTPS 服务。",
      "invalid_auth": "令牌无效，请确保该令牌在爱快后台拥有足够的接口权限。",
      "name_exists": "该集成名称已在使用中，请换一个名字（如：二楼路由）。",
      "unknown": "发生未知错误。"
    },
    "abort": {
      "already_configured": "该 iKuai 路由器已配置过。",
      "reconfigure_successful": "重新配置成功。"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "iKuai Connect 选项",
        "data": {
          "manage_action": "终端追踪管理",
          "scan_interval": "数据更新间隔 (秒)",
          "offline_grace_period": "全局离线判定缓冲时间 (秒)"
        }
      },
      "scan": {
        "title": "选择追踪终端",
        "description": "请勾选您想要在 HA 中追踪状态的在线终端。",
        "data": {
          "devices": "在线终端列表"
        }
      },
      "configure_devices": {
        "title": "配置终端追踪选项",
        "description": "正在配置 **{device}** , \n 请为选中的终端设置显示名称和离线缓冲时间, \n 剩余待配置设备: {remaining} 个, \n 注：手机判定时间建议设置600秒。",
        "data": {
          "name": "显示名称",
          "offline_grace_period": "离线判定延迟时间 (30-3600秒)"
        }
      },
      "remove": {
        "title": "移除追踪终端",
        "data": {
          "devices_to_remove": "已追踪设备列表"
        }
      }
    },
    "error": {
      "no_devices_selected": "您没有选择任何设备。",
      "no_new_devices_found": "未发现未添加的新在线终端。"
    }
  },
  "selector": {
    "manage_action": {
      "options": {
        "none": "无 (仅保存基础设置并退出)",
        "add": "➕ 添加新的追踪终端",
        "remove": "➖ 移除现有的追踪"
      }
    }
  },   
  "entity": {
